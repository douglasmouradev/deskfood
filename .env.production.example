# Copie para .env no servidor: cp .env.production.example .env
# Gere APP_SECRET: openssl rand -hex 32
# Gere PIX_WEBHOOK_SECRET: openssl rand -hex 24
# Gere HEALTH_TOKEN: openssl rand -hex 16

APP_NAME="Desk Food"
APP_ENV=production
APP_URL=https://deskfood.seudominio.com.br
APP_SECRET=SUBSTITUA_pelo_openssl_rand_hex_32
INSTALL_KEY=SUBSTITUA_chave_longa_aleatoria

APP_META_DESCRIPTION="Desk Food — delivery multi-unidade."
APP_COMMERCIAL_COMPANY="Sua Empresa"
APP_COMMERCIAL_EMAIL=comercial@seudominio.com.br
APP_COMMERCIAL_PHONE_LABEL="(00) 00000-0000"
APP_COMMERCIAL_PHONE_TEL="+5500000000000"

OPERATOR_BOARD_POLL_MS=20000
ALLOW_INSTALL=0
TAILWIND_CDN=0

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=desk_food
DB_USERNAME=deskfood_app
DB_PASSWORD=SUBSTITUA_senha_forte

LOGIN_RATE_MAX=8
LOGIN_RATE_WINDOW=900
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=3600
SESSION_IDLE_MINUTES=120
SESSION_CLEANUP_DAYS=14
LOCATION_RETENTION_DAYS=30
# TRUSTED_PROXIES=10.0.0.0/8

# Obrigatório em produção (bootstrap bloqueia sem eles)
HEALTH_TOKEN=SUBSTITUA_openssl_rand_hex_16
PIX_WEBHOOK_SECRET=SUBSTITUA_openssl_rand_hex_24

# Mapa de rastreio + geocodificação de endereços (Maps JavaScript + Geocoding API)
GOOGLE_MAPS_API_KEY=

# Fila assíncrona recomendada (cron: php bin/worker.php)
JOBS_ASYNC=1
CART_PERSIST=1

# Alertas de erro (Slack webhook ou Sentry ingest URL)
# ERROR_WEBHOOK_URL=

SMS_PROVIDER=zenvia
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=
SMS_SENDER=DeskFood

PIX_PROVIDER=efipay
PIX_SANDBOX=0
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_MP_PUBLIC_KEY=
PIX_PIX_KEY=
PIX_MTLS_CERT=/etc/deskfood/efi-cert.pem
PIX_MTLS_KEY=/etc/deskfood/efi-key.pem
# PIX_MP_WEBHOOK_SECRET=assinatura_webhooks_mercadopago
# PIX_EFI_TRUST_WEBHOOK=1

UPLOAD_MAX_SIZE=2097152
UPLOAD_PATH=public/uploads

TERMS_VERSION=1.0
PRIVACY_VERSION=1.0
DPO_NAME=Encarregado de Dados
DPO_EMAIL=privacidade@seudominio.com.br

NOTIFY_ORDER_SMS=1
NOTIFY_ORDER_EMAIL=1
NOTIFY_CUSTOMER_EMAIL=1

MAIL_DRIVER=smtp
MAIL_HOST=smtp.seudominio.com.br
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@seudominio.com.br
MAIL_FROM_NAME="Desk Food"

LOG_LEVEL=warning
LOG_PATH=storage/logs

# Opcional
# ANALYTICS_GA_ID=
# CATALOG_CACHE_TTL=120
