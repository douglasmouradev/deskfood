{
    "name": "deskfood/saas",
    "description": "Desk Food — SaaS de delivery (PHP 8.3, MVC manual)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ramsey/uuid": "^4.7",
        "dompdf/dompdf": "^2.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "lint": "find app config public install.php -name '*.php' -print0 | xargs -0 -n1 php -l"
    }
}
