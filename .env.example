# Aplicação
APP_NAME="Desk Food"
APP_ENV=local
APP_URL=http://localhost:8080
APP_SECRET=altere_esta_chave_com_32bytes_hex_ou_mais
INSTALL_KEY=chave_segura_para_instalar_via_browser

# SEO (opcional): descrição padrão para meta em páginas públicas
APP_META_DESCRIPTION="Desk Food — delivery multi-unidade com PIX, caixa e LGPD."

# Contato comercial (rodapé, landing, /ajuda)
APP_COMMERCIAL_COMPANY="TDesk Solutions"
APP_COMMERCIAL_EMAIL="comercial@tdesksolutions.com.br"
APP_COMMERCIAL_PHONE_LABEL="71 99708-7082"
APP_COMMERCIAL_PHONE_TEL="+5571997087082"

# Operador: atualização automática do quadro de pedidos (ms; 0 = desligado)
OPERATOR_BOARD_POLL_MS=20000

# Instalação: em produção use ALLOW_INSTALL=0 (browser só com ALLOW_INSTALL=1)
ALLOW_INSTALL=0

# CSS: 0 = Tailwind compilado (npm run build). 1 = CDN (dev sem Node)
TAILWIND_CDN=0

# Cache do cardápio público (segundos; 0 = desligado)
CATALOG_CACHE_TTL=120

# Healthcheck: obrigatório em APP_ENV=production (header X-Health-Token)
# HEALTH_TOKEN=

# Sessão: minutos de inatividade antes de expirar (padrão 120)
SESSION_IDLE_MINUTES=120

# Limpeza de sessões (bin/cleanup-old-data.php)
SESSION_CLEANUP_DAYS=14

# Banco de Dados
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=desk_food
DB_USERNAME=root
DB_PASSWORD=

# Segurança — login admin/operador (tentativas / janela em segundos)
LOGIN_RATE_MAX=8
LOGIN_RATE_WINDOW=900

# Rate limit genérico (checkout, webhook PIX)
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=3600

# Proxies confiáveis (IPs ou CIDR) — só então X-Forwarded-For é usado para rate limit
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

# SMS: log = dev (código em storage/logs/app-*.log) | zenvia = recomendado BR | twilio
# Ver README.md seção "SMS (Zenvia) em produção"
SMS_PROVIDER=log
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=
SMS_SENDER=DeskFood

# PIX (mock|efipay|mercadopago)
PIX_PROVIDER=mock
PIX_SANDBOX=0
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_MP_PUBLIC_KEY=
PIX_PIX_KEY=
# Certificado mTLS Efi (caminhos absolutos no servidor)
# PIX_MTLS_CERT=/etc/deskfood/efi-cert.pem
# PIX_MTLS_KEY=/etc/deskfood/efi-key.pem
# Webhook: header X-Deskfood-Webhook-Secret ou Authorization: Bearer <valor>
PIX_WEBHOOK_SECRET=
# Mercado Pago: assinatura x-signature (painel MP > Webhooks)
# PIX_MP_WEBHOOK_SECRET=
# Efi: aceitar webhook PIX sem header Deskfood (use com firewall/IP no Nginx)
# PIX_EFI_TRUST_WEBHOOK=0

# Upload
UPLOAD_MAX_SIZE=2097152
UPLOAD_PATH=public/uploads

# LGPD / documentos
TERMS_VERSION=1.0
PRIVACY_VERSION=1.0
DPO_NAME=Encarregado de Dados Desk Food
DPO_EMAIL=privacidade@seudominio.com.br

# Notificações de pedido por SMS ao cliente
NOTIFY_ORDER_SMS=0

# E-mail (log | smtp) — pedidos novos notificam APP_COMMERCIAL_EMAIL se NOTIFY_ORDER_EMAIL=1
MAIL_DRIVER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@seudominio.com.br
MAIL_FROM_NAME="Desk Food"
NOTIFY_ORDER_EMAIL=1
# E-mail ao cliente após pedido (requer e-mail em /cliente/lgpd/editar)
NOTIFY_CUSTOMER_EMAIL=0

# Analytics (opcional) — Google Analytics 4 measurement ID
ANALYTICS_GA_ID=

# Logs
LOG_LEVEL=debug
LOG_PATH=storage/logs
